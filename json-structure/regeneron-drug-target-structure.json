{
  "title": "Drug Target Structure",
  "description": "JSON structure documentation for the Regeneron Drug Target entity",
  "fields": [
    { "name": "targetId", "type": "string", "required": true, "description": "Unique target identifier" },
    { "name": "name", "type": "string", "required": true, "description": "Target name or gene symbol" },
    { "name": "targetType", "type": "string", "required": true, "description": "Protein, Gene, Pathway, or RNA" },
    { "name": "geneSymbol", "type": "string", "required": false, "description": "HGNC approved gene symbol" },
    { "name": "uniprotId", "type": "string", "required": false, "description": "UniProt accession number" },
    { "name": "biologicalFunction", "type": "string", "required": false, "description": "Target biological role" },
    { "name": "diseaseArea", "type": "array[string]", "required": false, "description": "Relevant disease areas" },
    { "name": "modality", "type": "string", "required": false, "description": "Drug modality (Antibody, Small Molecule, etc.)" },
    { "name": "geneticValidation", "type": "boolean", "required": false, "description": "Human genetics validation flag" },
    { "name": "rgcEvidence", "type": "boolean", "required": false, "description": "Regeneron Genetics Center evidence flag" }
  ]
}
